[global]
    # Position
    origin              = top-right
    offset              = 16x52
    gap_size            = 6

    # Geometry
    width               = 340
    height              = 120
    scale               = 0

    # Appearance
    frame_width         = 2
    frame_color         = "#45475a"
    corner_radius       = 8
    separator_height    = 2
    separator_color     = frame
    padding             = 12
    horizontal_padding  = 14

    # Font
    font                = Roboto 11

    # Markup & format
    markup              = full
    format              = "<b>%s</b>\n%b"
    word_wrap           = yes
    ellipsize           = middle
    ignore_newline      = no

    # Behaviour
    sort                = yes
    indicate_hidden     = yes
    stack_duplicates    = true
    hide_duplicate_count = false
    show_indicators     = yes
    sticky_history      = yes
    history_length      = 20
    idle_threshold      = 120

    # Timeouts (ms)
    show_age_threshold  = 60

    # Icons
    icon_theme          = Papirus-Dark
    enable_recursive_icon_lookup = true
    icon_position       = left
    min_icon_size       = 32
    max_icon_size       = 48

    # Misc
    browser             = firefox
    title               = Dunst
    class               = Dunst
    mouse_left_click    = close_current
    mouse_middle_click  = do_action, close_current
    mouse_right_click   = close_all

[urgency_low]
    background          = "#1e1e2e"
    foreground          = "#bac2de"
    frame_color         = "#45475a"
    timeout             = 4

[urgency_normal]
    background          = "#1e1e2e"
    foreground          = "#cdd6f4"
    frame_color         = "#89b4fa"
    timeout             = 6

[urgency_critical]
    background          = "#1e1e2e"
    foreground          = "#f38ba8"
    frame_color         = "#f38ba8"
    timeout             = 0
