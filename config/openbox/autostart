#!/bin/bash
# Openbox autostart — runs once after the WM initialises

# ── Screen power management: disable blanking/sleep ──────────────────────────
xset s off
xset -dpms
xset s noblank

# ── Apply X resource settings (xterm colors, DPI, etc.) ──────────────────────
xrdb -merge /root/.Xresources

# ── NumLock on ────────────────────────────────────────────────────────────────
numlockx on &

# ── Wallpaper ─────────────────────────────────────────────────────────────────
feh --bg-scale /root/wallpaper.png &

# ── Notification daemon ───────────────────────────────────────────────────────
dunst &

# ── Panel ─────────────────────────────────────────────────────────────────────
tint2 &
